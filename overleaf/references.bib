@article{scharkow_thematic_2013,
	title = {Thematic content analysis using supervised machine learning: {An} empirical evaluation using {German} online news},
	volume = {47},
	issn = {0033-5177, 1573-7845},
	shorttitle = {Thematic content analysis using supervised machine learning},
	url = {http://link.springer.com/10.1007/s11135-011-9545-7},
	doi = {10.1007/s11135-011-9545-7},
	abstract = {In recent years, two approaches to automatic content analysis have been introduced in the social sciences: semantic network analysis and supervised text classiﬁcation. We argue that, although less linguistically sophisticated than semantic parsing techniques, statistical machine learning offers many advantages for applied communication research. By using manually coded material for training, supervised classiﬁcation seamlessly bridges the gap between traditional and automatic content analysis. In this paper, we brieﬂy introduce the conceptual foundations of machine learning approaches to text classiﬁcation and discuss their application in social science research. We then evaluate their potential in an experimental study in which German online news was coded with established thematic categories. Moreover, we investigate whether and how linguistic preprocessing can improve classiﬁcation quality. Results indicate that supervised text classiﬁcation is generally robust and reliable for some categories, but may even be useful when it fails.},
	language = {en},
	number = {2},
	urldate = {2024-01-25},
	journal = {Quality \& Quantity},
	author = {Scharkow, Michael},
	month = feb,
	year = {2013},
	pages = {761--773},
	file = {Scharkow - 2013 - Thematic content analysis using supervised machine.pdf:/Users/cbarrie6/Zotero/storage/B6VEQFGC/Scharkow - 2013 - Thematic content analysis using supervised machine.pdf:application/pdf},
}

