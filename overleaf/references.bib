}

@misc{zhang_prefer_2023,
	title = {{PREFER}: {Prompt} {Ensemble} {Learning} via {Feedback}-{Reflect}-{Refine}},
	shorttitle = {{PREFER}},
	url = {http://arxiv.org/abs/2308.12033},
	abstract = {As an effective tool for eliciting the power of Large Language Models (LLMs), prompting has recently demonstrated unprecedented abilities across a variety of complex tasks. To further improve the performance, prompt ensemble has attracted substantial interest for tackling the hallucination and instability of LLMs. However, existing methods usually adopt a two-stage paradigm, which requires a pre-prepared set of prompts with substantial manual effort, and is unable to perform directed optimization for different weak learners. In this paper, we propose a simple, universal, and automatic method named PREFER (PRompt Ensemble learning via FeedbackREflect-Refine) to address the stated limitations. Specifically, given the fact that weak learners are supposed to focus on hard examples during boosting, PREFER builds a feedback mechanism for reflecting on the inadequacies of existing weak learners. Based on this, the LLM is required to automatically synthesize new prompts for iterative refinement. Moreover, to enhance stability of the prompt effect evaluation, we propose a novel prompt bagging method involving forward and backward thinking, which is superior to majority voting and is beneficial for both feedback and weight calculation in boosting. Extensive experiments demonstrate that our PREFER achieves state-of-the-art performance in multiple types of tasks by a significant margin. We have made our code publicly available1.},
	language = {en},
	urldate = {2024-01-25},
	publisher = {arXiv},
	author = {Zhang, Chenrui and Liu, Lin and Wang, Jinpeng and Wang, Chuyuan and Sun, Xiao and Wang, Hongyu and Cai, Mingchen},
	month = aug,
	year = {2023},
	note = {arXiv:2308.12033 [cs]},
	keywords = {Computer Science - Artificial Intelligence, Computer Science - Computation and Language},
	annote = {Comment: 8 pages, 4 figures},
	file = {Zhang et al. - 2023 - PREFER Prompt Ensemble Learning via Feedback-Refl.pdf:/Users/cbarrie6/Zotero/storage/7UN92FRC/Zhang et al. - 2023 - PREFER Prompt Ensemble Learning via Feedback-Refl.pdf:application/pdf},
}

@misc{guo_towards_2023,
	title = {Towards {Optimizing} with {Large} {Language} {Models}},
	url = {http://arxiv.org/abs/2310.05204},
	abstract = {In this study, we evaluate the optimization capabilities of Large Language Models (LLMs) across diverse tasks and data sizes. The tasks involve unique optimization domains, requiring LLMs to iteratively generate and evaluate solutions through interactive prompting. Each optimization step involves the generation of new solutions based on past results, which are then evaluated and considered in subsequent steps. We also introduce three metrics to comprehensively assess task performance from various perspectives. These metrics are designed to be applicable across a wide range of optimization tasks and are less sensitive to variations in test samples. Our findings reveal that LLMs demonstrate robust optimization capabilities when dealing with small-sized samples. However, the performance of LLMs is notably influenced by factors such as data size and values, underscoring the importance of further research in the domain of optimization tasks for LLMs.},
	language = {en},
	urldate = {2024-01-25},
	publisher = {arXiv},
	author = {Guo, Pei-Fu and Chen, Ying-Hsuan and Tsai, Yun-Da and Lin, Shou-De},
